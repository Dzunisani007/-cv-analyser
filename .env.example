# General
ENVIRONMENT=development
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8000
ALLOW_ORIGINS=http://localhost:3000

# Auth & security
# Option B behavior:
# - If AUTH_SECRET is empty AND PUBLIC_UPLOADS=true, /upload is allowed without Authorization header.
# - For production set AUTH_SECRET and set PUBLIC_UPLOADS=false.
AUTH_SECRET=
PUBLIC_UPLOADS=true
SIGNING_SECRET=

# Database
DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/cv_service
PGVECTOR_ENABLED=false

# Storage
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./.storage

# Cloudinary (only if STORAGE_BACKEND=cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# S3 (only if STORAGE_BACKEND=s3)
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Models
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
NER_MODEL=dslim/bert-base-NER
GENERATION_MODEL=mistralai/Mistral-7B-Instruct-v0.1
HF_API_TOKEN=

# Optional LLM rewrite (local only)
LLM_MODE=none
LLAMA_MODEL_PATH=

# Ops/testing
WORKER_COUNT=2
INLINE_JOBS=false
MAX_UPLOAD_MB=15
PROMETHEUS_ENABLED=true
DEBUG=false
SENTRY_DSN=
RUN_MIGRATIONS_ON_START=false
