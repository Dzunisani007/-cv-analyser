# General
ENVIRONMENT=development
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8000
ALLOW_ORIGINS=http://localhost:3000

# Auth & security
# Option B behavior:
# - If AUTH_SECRET is empty AND PUBLIC_UPLOADS=true, /upload is allowed without Authorization header.
# - For production set AUTH_SECRET and set PUBLIC_UPLOADS=false.
AUTH_SECRET=
PUBLIC_UPLOADS=true
SIGNING_SECRET=

# Database
DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/cv_service

# Storage
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./.storage

# Models
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
NER_MODEL=dslim/bert-base-NER
NER_MODE=transformers
GLINER_MODEL=urchade/gliner_base-v2.1
STRUCTURED_EXTRACTION_MODEL=microsoft/DialoGPT-medium
ENABLE_STRUCTURED_EXTRACTION=true
GENERATION_MODEL=

# Hugging Face
HF_API_TOKEN=
SKIP_MODEL_LOAD=false
WORKER_COUNT=2

# Feature Flags
INLINE_JOBS=true
PROMETHEUS_ENABLED=true
DEBUG=false
PGVECTOR_ENABLED=false

# Optional LLM rewrite (local only)
LLM_MODE=none
LLAMA_MODEL_PATH=

# Ops/testing
MAX_UPLOAD_MB=15
SENTRY_DSN=
RUN_MIGRATIONS_ON_START=false
