# Production Environment Variables for Render Deployment
# Replace with actual values - NEVER commit real credentials

# General
ENVIRONMENT=production
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8000
ALLOW_ORIGINS=https://your-main-app-domain.com

# Auth & security
AUTH_SECRET=your-actual-auth-secret-here
PUBLIC_UPLOADS=false
SIGNING_SECRET=your-signing-secret-here

# Database
DATABASE_URL=postgresql://username:password@host/database?sslmode=require
PGVECTOR_ENABLED=false

# Storage
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./.storage

# Models (local mode for production)
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
NER_MODEL=bert-base-NER
GENERATION_MODEL=microsoft/DialoGPT-medium
HF_API_TOKEN=

# Production settings
SKIP_MODEL_LOAD=true
LLM_MODE=none

# Operations
WORKER_COUNT=2
INLINE_JOBS=false
MAX_UPLOAD_MB=15
PROMETHEUS_ENABLED=true
DEBUG=false
SENTRY_DSN=
